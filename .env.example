# Browser requests stay same-origin and go through the Nuxt proxy route.
NUXT_BASE_API_URL=/api

# Nuxt server and proxy forward requests to the Django API here.
NUXT_INTERNAL_API_URL=https://replace-backend-hostname/api
NUXT_PUBLIC_SITE_URL=https://replace-frontend-hostname
NUXT_PUBLIC_SITE_ENV=staging
# Keep false on local, staging, and preview deployments. Turn true only on production launch.
NUXT_PUBLIC_ALLOW_INDEXING=false
NUXT_PUBLIC_SITE_NAME=FlexDrive
NUXT_PUBLIC_DEFAULT_SEO_TITLE=FlexDrive - ავტონაწილების ონლაინ მაღაზია
NUXT_PUBLIC_DEFAULT_SEO_DESCRIPTION=შეიძინე ხარისხიანი ავტონაწილები FlexDrive-ზე. მოძებნე ნაწილი OEM-ით, SKU-ით ან კატეგორიით და შეუკვეთე ონლაინ მარტივად.
NUXT_PUBLIC_DEFAULT_SEO_IMAGE=/favicon.ico
NUXT_PUBLIC_RECAPTCHA_SITE_KEY=replace-recaptcha-site-key
NUXT_PUBLIC_GTM_ID=
